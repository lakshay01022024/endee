# ── Endee Vector Database ──────────────────────────
ENDEE_HOST=localhost
ENDEE_PORT=8080
ENDEE_AUTH_TOKEN=

# ── Embedding Model ───────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM Configuration ─────────────────────────────
# Local model (default — no API key needed)
LLM_MODEL=google/flan-t5-base

# Optional: Use OpenAI instead of local model
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-3.5-turbo

# ── Application ────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
INDEX_NAME=knowledge_base
CHUNK_SIZE=512
CHUNK_OVERLAP=50
